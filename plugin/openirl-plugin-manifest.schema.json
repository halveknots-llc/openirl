{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenIRL Plugin Manifest",
  "type": "object",
  "required": [
    "name",
    "version",
    "permissions",
    "webhooks"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "webhooks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
